{
  "name": "wanjiedaoyou",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "auth:generate": "bunx auth@latest generate --config src/server/lib/auth/auth.ts --output src/server/lib/auth/better-auth.schema.sql --yes",
    "auth:info": "bunx auth@latest info --config src/server/lib/auth/auth.ts --json",
    "auth:migrate": "bunx auth@latest migrate --config src/server/lib/auth/auth.ts --yes",
    "build": "bun run build:client && bun run build:server",
    "build:client": "tsc -b tsconfig.app.json && vite build --mode client",
    "build:server": "tsc -b tsconfig.node.json && vite build --mode server",
    "check": "bun run build",
    "dev": "bun scripts/dev.ts",
    "dev:api": "bun scripts/dev-api.ts",
    "dev:web": "vite",
    "lint": "eslint .",
    "preview": "bun run build && bun run dist/index.js",
    "start": "bun run dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^2.0.16",
    "@ai-sdk/deepseek": "^3.0.13",
    "@better-auth/i18n": "^1.6.23",
    "@marsidev/react-turnstile": "^1.5.3",
    "@microfleet/ioredis-lock": "^6.0.1",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@tailwindcss/vite": "^4.3.3",
    "ai": "^7.0.34",
    "better-auth": "^1.6.23",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-format": "^3.1.2",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.31",
    "ioredis": "^5.11.1",
    "jsonrepair": "^3.15.0",
    "littlejsengine": "^1.18.21",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-router": "^8.2.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@hono/vite-build": "1.11.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/d3-format": "^3.0.4",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "^3.9.6",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
